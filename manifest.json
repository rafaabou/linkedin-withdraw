{
  "manifest_version": 3,
  "name": "LinkedIn Withdraw Automation",
  "version": "3.0",
  "description": "Automates withdrawing LinkedIn sent invitations",
  "homepage_url": "https://github.com/rafaabou/linkedin-withdraw",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/mynetwork/invitation-manager/sent/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "linkedin-withdraw@rafaabou.dev",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {}
  }
}
