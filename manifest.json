{
  "manifest_version": 2,
  "name": "LinkedIn Withdraw Automation",
  "version": "2.0",
  "description": "Automates withdrawing LinkedIn sent invitations",
  "homepage_url": "https://www.linkedin.com/",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "linkedin-withdraw@halimbahae.dev",
      "strict_min_version": "58.0"
    }
  }
}
